# ============================================================
# Chutki Ki Duniya - Environment Variables
# ============================================================
#
# HOW TO USE THIS FILE:
# 1. Copy this file and rename the copy to `.env.local`
# 2. Fill in the values as you sign up for each service
# 3. NEVER commit .env.local to GitHub — it's gitignored
# 4. In Vercel, add these same variables under Settings → Environment Variables
#
# For Phase 1 launch (fake auth + no payments), you need ZERO of these.
# The site runs fine with no env vars at all.
#
# Add variables here as you enable each feature below.
# ============================================================


# ============================================================
# SUPABASE (database + login + file storage) — add when going live
# Get these from: supabase.com → your project → Settings → API
# ============================================================
# NEXT_PUBLIC_SUPABASE_URL=https://xxxxx.supabase.co
# NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJxxxxx
# SUPABASE_SERVICE_ROLE_KEY=eyJxxxxx   # SERVER-ONLY, never expose in browser


# ============================================================
# CLOUDFLARE R2 (real PDF storage) — add when uploading real PDFs
# Get these from: dash.cloudflare.com → R2 → Manage API Tokens
# ============================================================
# R2_ACCOUNT_ID=xxxxx
# R2_ACCESS_KEY_ID=xxxxx
# R2_SECRET_ACCESS_KEY=xxxxx
# R2_BUCKET_NAME=chutki-sheets


# ============================================================
# RAZORPAY (real payments) — add when ready to take payments
# Get these from: dashboard.razorpay.com → Settings → API Keys
# ============================================================
# RAZORPAY_KEY_ID=rzp_test_xxxxx
# RAZORPAY_KEY_SECRET=xxxxx
# RAZORPAY_WEBHOOK_SECRET=xxxxx


# ============================================================
# RESEND (transactional emails) — add when sending real emails
# Get from: resend.com → API Keys
# ============================================================
# RESEND_API_KEY=re_xxxxx
